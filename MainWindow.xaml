<Window x:Class="PCOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Optimizer Pro" Height="700" Width="1200"
        Background="#1a1a1a" Foreground="White"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    <Grid>
        <!-- Left Sidebar Navigation -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#2d2d2d" VerticalAlignment="Stretch">
            <TextBlock Text="PC OPTIMIZER PRO" FontSize="18" FontWeight="Bold" Foreground="#00d4ff" Padding="20,20,20,10"/>
            <TextBlock Text="v1.0.0" FontSize="10" Foreground="#888" Padding="20,0,20,20"/>
            <Separator Foreground="#444" Margin="10,0"/>
            
            <Button x:Name="DashboardBtn" Content="📊 Dashboard" Style="{StaticResource NavButton}" Click="DashboardBtn_Click"/>
            <Button x:Name="VirusScanBtn" Content="🔍 Virus Scanner" Style="{StaticResource NavButton}" Click="VirusScanBtn_Click"/>
            <Button x:Name="DiskCleanBtn" Content="💾 Disk Cleanup" Style="{StaticResource NavButton}" Click="DiskCleanBtn_Click"/>
            <Button x:Name="RAMOptBtn" Content="⚡ RAM Optimizer" Style="{StaticResource NavButton}" Click="RAMOptBtn_Click"/>
            <Button x:Name="StartupBtn" Content="🚀 Startup Manager" Style="{StaticResource NavButton}" Click="StartupBtn_Click"/>
            <Button x:Name="RegBtn" Content="🗂️ Registry Cleaner" Style="{StaticResource NavButton}" Click="RegBtn_Click"/>
            <Button x:Name="ProcessBtn" Content="⚙️ Process Manager" Style="{StaticResource NavButton}" Click="ProcessBtn_Click"/>
            <Button x:Name="MonitorBtn" Content="📈 System Monitor" Style="{StaticResource NavButton}" Click="MonitorBtn_Click"/>
            <Button x:Name="SettingsBtn" Content="⚙️ Settings" Style="{StaticResource NavButton}" Click="SettingsBtn_Click"/>
            
            <Separator Foreground="#444" Margin="10,20"/>
            <Button x:Name="BoostBtn" Content="⚡ ONE-CLICK BOOST" Background="#00d4ff" Foreground="Black" Padding="10,15" Margin="10" Click="BoostBtn_Click" FontWeight="Bold"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="#1a1a1a">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ContentControl x:Name="ContentArea" Grid.Row="0"/>

            <!-- Status Bar -->
            <StackPanel Grid.Row="1" Background="#2d2d2d" Orientation="Horizontal" Height="60" Margin="20">
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#00d4ff" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock x:Name="CPUStatus" Text="CPU: 0%" Foreground="White" Margin="20,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock x:Name="RAMStatus" Text="RAM: 0%" Foreground="White" Margin="20,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock x:Name="TempStatus" Text="Temp: 0°C" Foreground="White" Margin="20,0,0,0" VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Grid>

    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00d4ff"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>
